[Unit]
Description=llama-server (Vulkan - Strix Halo - kyuz0)
After=default.target

[Service]
Type=simple
# kyuz0's Vulkan llama-server binary with LD_LIBRARY_PATH wrapper.
# The snap's bundled llama-server has recurring ABI breakage (missing symbols
# like ggml_build_forward_select after snap auto-updates), so we run kyuz0's
# self-contained build directly — no dependency on the snap at runtime.
#
# IMPORTANT flags:
#   --mmap        Required. --no-mmap loads the entire model into system RAM
#                 (72GB for 122B) which OOMs the 30GB system memory and causes
#                 massive swap thrashing. With mmap, the Vulkan driver maps
#                 model weights directly into the 96GB unified VRAM.
#   --no-warmup   Skip the warmup inference pass to reduce startup time.
#   -ngl 99       Offload all layers to GPU (Vulkan).
#   --jinja       Enable Jinja2 chat templates (required for Qwen3.5).
#   --reasoning-format auto   Stream reasoning_content for thinking models.
#
# Model path: update the snapshot hash if you re-download the model.
ExecStart=/home/awpapa/.lemonade/bin/llamacpp/vulkan/llama-server-wrapper.sh \
  -m /mnt/Esuna/lemonade-cache/huggingface/hub/models--unsloth--Qwen3.5-122B-A10B-GGUF/snapshots/51eab4d59d53f573fb9206cb3ce613f1d0aa392b/UD-Q4_K_XL/Qwen3.5-122B-A10B-UD-Q4_K_XL-00001-of-00003.gguf \
  --ctx-size 131072 \
  --port 8001 \
  --host 0.0.0.0 \
  --no-warmup \
  -ngl 99 \
  --mmap \
  --jinja \
  --reasoning-format auto
Restart=on-failure
RestartSec=10

[Install]
WantedBy=default.target
