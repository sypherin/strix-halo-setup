[Unit]
Description=llama-server (Vulkan - Strix Halo)
After=default.target

[Service]
Type=simple
# Standalone llama-server using official llama.cpp Vulkan build (b8299+).
# Bypasses lemonade router entirely — no snap dependency at runtime.
#
# Binary location: ~/.lemonade/bin/llamacpp/vulkan/
# The wrapper script sets LD_LIBRARY_PATH so shared libs are found.
#
# IMPORTANT flags:
#   --mmap           REQUIRED. Without it, the 72GB model is loaded into system
#                    RAM (only 30GB), causing swap thrashing and system freeze.
#                    With mmap, Vulkan maps weights into 96GB unified VRAM.
#   --no-warmup      Skip warmup inference pass to reduce startup time.
#   -ngl 99          Offload all layers to GPU (Vulkan).
#   --jinja          Enable Jinja2 chat templates (required for Qwen3.5).
#   --reasoning-format auto   Stream reasoning_content for thinking models.
#   --ubatch-size 512   Prevents MoE prefill regression on Vulkan (b7684+).
#
# Model path: update the snapshot hash if you re-download the model.
ExecStart=/home/awpapa/.lemonade/bin/llamacpp/vulkan/llama-server-wrapper.sh \
  -m /mnt/Esuna/lemonade-cache/huggingface/hub/models--unsloth--Qwen3.5-122B-A10B-GGUF/snapshots/51eab4d59d53f573fb9206cb3ce613f1d0aa392b/UD-Q4_K_XL/Qwen3.5-122B-A10B-UD-Q4_K_XL-00001-of-00003.gguf \
  --ctx-size 131072 \
  --port 8001 \
  --host 0.0.0.0 \
  --no-warmup \
  -ngl 99 \
  --mmap \
  --jinja \
  --reasoning-format auto \
  --ubatch-size 512
Restart=on-failure
RestartSec=10

[Install]
WantedBy=default.target
