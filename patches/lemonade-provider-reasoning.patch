=== Patch 1: reasoning_content support (line ~392) ===
Find:
    const maybeThinking = choice?.thinking ?? deltaObj?.thinking;
Replace with:
    const maybeThinking = choice?.thinking ?? deltaObj?.thinking ?? deltaObj?.reasoning_content;

=== Patch 2: ThinkingPart fallback (line ~408-416) ===
Find:
                if (text) {
                    if (ThinkingCtor) {
                        progress.report(new ThinkingCtor(text, id, metadata));
                    }
                    emitted = true;
                }
Replace with:
                if (text) {
                    if (ThinkingCtor) {
                        progress.report(new ThinkingCtor(text, id, metadata));
                    } else {
                        // Fallback: emit thinking as regular text so Copilot doesn't timeout
                        progress.report(new vscode.LanguageModelTextPart(text));
                    }
                    emitted = true;
                }

